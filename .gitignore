# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
jspm_packages/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
dist-electron/
out/
build/Release

# ── Native module build artifacts ────────────────────────────────────────────
native-module/target/
native-module/*.node
# Keep index.js / index.d.ts / Cargo.toml / src — only exclude compiled output
# (individual .node files committed alongside src for distribution)

# ── Release artifacts ─────────────────────────────────────────────────────────
release/
*.dmg
*.dmg.blockmap
*.zip
*.zip.blockmap
*.exe
*.exe.blockmap
*.AppImage
*.snap
*.deb
*.rpm
builder-debug.yml
builder-effective-config.yaml

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ── OS generated ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.cursorrules
.windsurfrules

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Coverage / test output ────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/
test-results/
playwright-report/

# ── Temp / scratch ────────────────────────────────────────────────────────────
temp/
temp_code_expansion/
tmp/
*.patch
*.csv

# ── Submodules / private packages ────────────────────────────────────────────
