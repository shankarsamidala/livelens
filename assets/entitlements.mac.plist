<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- JIT + memory permissions for V8 JavaScript engine (arm64 / Apple Silicon required) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- Microphone access (CPAL / MicrophoneCapture) -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!--
        Screen Recording / System Audio Capture:
        Required for BOTH ScreenCaptureKit (SCK) and the CoreAudio Global Process Tap.
        Without this entitlement the macOS TCC layer silently rejects the permission
        request in production builds. Dev (npm start / Electron CLI) bypasses TCC checks
        because it runs as an unsigned binary, which is why audio worked in dev but not
        in the packaged app.
    -->
    <key>com.apple.security.screen-capture</key>
    <true/>

    <!-- Apple Events (automation / AppleScript support) -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
